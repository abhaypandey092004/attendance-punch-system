import csv
import os
import datetime

FILE_NAME = "attendance.csv"

def initialize_file():
    if not os.path.exists(FILE_NAME):
        with open(FILE_NAME, 'w', newline='') as f:
            writer = csv.writer(f)
            writer.writerow(["Name", "Date", "Punch In", "Punch Out", "Hours Worked"])

def punch_in(name):
    initialize_file()
    with open(FILE_NAME, 'a', newline='') as f:
        writer = csv.writer(f)
        now = datetime.datetime.now()
        writer.writerow([name, now.strftime("%Y-%m-%d"), now.strftime("%H:%M:%S"), "---", "---"])
    print(f"✅ {name} punched in at {now.strftime('%H:%M:%S')}")

def punch_out(name):
    initialize_file()
    rows = []
    found = False
    
    with open(FILE_NAME, 'r') as f:
        reader = csv.reader(f)
        rows = list(reader)
    
    with open(FILE_NAME, 'w', newline='') as f:
        writer = csv.writer(f)
        now = datetime.datetime.now()
        
        for row in rows:
            if len(row) > 0 and row[0].lower() == name.lower() and row[3] == "---":
                row[3] = now.strftime("%H:%M:%S")
                # Calculate hours
                try:
                    time_in = datetime.datetime.strptime(row[2], "%H:%M:%S")
                    time_out = now
                    duration = (time_out - time_in).seconds / 3600
                    row[4] = str(round(duration, 2))
                except:
                    row[4] = "Error"
                found = True
            
            writer.writerow(row)
    
    if found:
        print(f"✅ {name} punched out at {now.strftime('%H:%M:%S')}")
    else:
        print(f"❌ No active punch-in found for {name}")

def view_records():
    initialize_file()
    print("\n" + "="*60)
    print("ATTENDANCE RECORDS")
    print("="*60)
    with open(FILE_NAME, 'r') as f:
        reader = csv.reader(f)
        for row in reader:
            print(f"{row[0]:<15} | {row[1]:<12} | {row[2]:<8} | {row[3]:<8} | {row[4]:<8}")
    print("="*60 + "\n")

def main():
    while True:
        print("=== ATTENDANCE SYSTEM ===")
        print("1. Punch In")
        print("2. Punch Out")
        print("3. View Records")
        print("4. Exit")
        
        choice = input("Enter choice (1-4): ")
        name = input("Enter your name: ")
        
        if choice == '1':
            punch_in(name)
        elif choice == '2':
            punch_out(name)
        elif choice == '3':
            view_records()
        elif choice == '4':
            break
        else:
            print("Invalid choice!")

if __name__ == "__main__":
    main()